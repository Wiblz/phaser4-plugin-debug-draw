{
  "name": "phaser-plugin-debug-draw",
  "version": "8.0.0",
  "description": "Simple debug display for Phaser 3 and Phaser 4",
  "main": "dist/main.js",
  "module": "dist/main.mjs",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    }
  },
  "files": [
    "/dist",
    "/src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "preversion": "npm run build && git add dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samme/phaser-plugin-debug-draw.git"
  },
  "keywords": [
    "phaser-plugin",
    "phaser3-plugin",
    "phaser4-plugin",
    "debug",
    "debug-draw"
  ],
  "author": "samme",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/samme/phaser-plugin-debug-draw/issues"
  },
  "homepage": "https://github.com/samme/phaser-plugin-debug-draw#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "phaser": "^3.90.0",
    "phaser-v4": "npm:phaser@^4.0.0-rc.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "phaser": "^3.53.0 || ^4.0.0"
  }
}
